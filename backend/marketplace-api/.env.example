DATABASE_URL="postgresql://agri:agri_dev_pass@localhost:5433/agri_marketplace?schema=public"
# Monorepo root .env often uses DATABASE_URL for MongoDB. Point Prisma at Postgres with either
# backend/marketplace-api/.env (above) or AGRI_DATABASE_URL in the repo root .env:
# AGRI_DATABASE_URL="postgresql://agri:agri_dev_pass@localhost:5433/agri_marketplace?schema=public"
REDIS_URL="redis://localhost:6380"
JWT_SECRET="change-me-in-production-min-32-chars-long"
JWT_EXPIRES_DAYS="7"
OTP_DEV_CODE="123456"
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# AWS S3 — product images via presigned PUT (see POST /api/storage/presign-product-image in Swagger)
# IAM user or task role needs s3:PutObject on bucket/path product-images/*
AWS_REGION="ap-south-1"
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# Optional CloudFront or CDN origin URL (no trailing slash); else public URL uses virtual-hosted S3
PUBLIC_CDN_BASE=""
PORT=4000
CORS_ORIGIN="http://localhost:3000"
