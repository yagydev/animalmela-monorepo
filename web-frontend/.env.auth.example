# KisaanMela authentication (copy into .env.local for local dev)

# Required — signing access tokens (and legacy single-token flows)
JWT_SECRET=change-me-to-a-long-random-string

# Optional — split secrets (defaults: access uses JWT_SECRET, refresh uses JWT_SECRET_refresh)
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=

# Token lifetimes (optional)
# JWT_ACCESS_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d
# JWT_EXPIRES_IN=24h

# Harden OTP hashes at rest (optional; defaults to JWT_SECRET)
# OTP_PEPPER=

# MongoDB (required in production on Vercel)
MONGODB_URI=mongodb://localhost:27017/kisaanmela
# DATABASE_URL=  # alias accepted by lib/database.js

# Twilio SMS (omit for mock / console OTP in dev)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# OTP rate limit: max sends per phone per UTC hour (default 5)
# OTP_RATE_LIMIT_PER_HOUR=5

# Dev only — never enable in production (returns OTP in JSON when SMS mock)
# EXPOSE_OTP_IN_API=true
