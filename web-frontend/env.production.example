# =============================================================================
# Vercel: set these in the dashboard (do not commit secrets)
# Project → Settings → Environment Variables
# =============================================================================
#
# Root directory (if the repo is the monorepo):
#   Set "Root Directory" to `web-frontend` so this Next app is built.
#
# MongoDB (required for /events, CMS APIs, and most /api routes using Mongoose)
# -----------------------------------------------------------------------------
# 1. Add BOTH variables with the SAME Atlas connection string (some code reads
#    MONGODB_URI, some DATABASE_URL; dbConnect.ts accepts either).
# 2. Scope: enable at least "Production" and "Preview" (and "Development"
#    only if you use `vercel dev` against Atlas).
# 3. Do NOT prefix with NEXT_PUBLIC_ (the URI must stay server-only).
# 4. Atlas → Network Access: allow 0.0.0.0/0 (or Vercel’s egress IPs) so
#    serverless functions can connect.
# 5. URL-encode special characters in the password (e.g. @ → %40).
#
# Example (replace USER, PASSWORD, cluster host, database name):
#   mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/kisaanmela_db_dev?retryWrites=true&w=majority
#
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/kisaanmela_db_dev?retryWrites=true&w=majority
DATABASE_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/kisaanmela_db_dev?retryWrites=true&w=majority
#
# Optional: only if you rely on web-frontend/lib/config.js defaults
# DB_NAME=kisaanmela_db_dev
#
# =============================================================================
# Other production / Vercel variables (examples)
# =============================================================================
NODE_ENV=production
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app

# Public site URL (server + RSC): Vercel sets VERCEL_URL; you can override:
# NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app

# Nest Kisaan marketplace UI (/marketplace/kisaan) — your deployed API URL
NEXT_PUBLIC_KISAANMELA_MARKETPLACE_API_URL=https://your-marketplace-api.example.com/api

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
OPENWEATHER_API_KEY=your_openweather_api_key
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

JWT_SECRET=your_jwt_secret_key_for_production

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

WHATSAPP_API_URL=https://api.whatsapp.com
WHATSAPP_PHONE_NUMBER=+919876543210

REDIS_URL=your_redis_url_if_using_redis
CACHE_TTL=3600

NEXT_PUBLIC_GA_ID=your_google_analytics_id
