# Copy to .env.local for local overrides.
# Vercel: do not rely on monorepo root .env — set MONGODB_URI and DATABASE_URL
# in the Vercel project (see env.production.example).
#
# Stack: Next.js + Tailwind + TS (this app); MongoDB for CMS, events, and marketplace listings APIs.

# MongoDB — same Atlas cluster/db as monorepo (replace USER:PASSWORD). Use both keys; code reads either.
DATABASE_URL=mongodb+srv://USER:PASSWORD@cluster0.tpeb1bh.mongodb.net/kisaanmela_db_dev
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.tpeb1bh.mongodb.net/kisaanmela_db_dev

# Main KisaanMela backend (Mongo / Express-style APIs)
NEXT_PUBLIC_API_URL=http://localhost:8000/api
